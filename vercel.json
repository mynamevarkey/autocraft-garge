{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["main.html"]
      }
    },
    {
      "src": "cinematic/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/cinematic/(.*)",
      "dest": "/cinematic/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
